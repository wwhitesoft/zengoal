# ZenGoal — Environment Variables
# Copia in .env e compila i valori reali (non committare .env)

# --- Google Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview

# --- Google Cloud ---
PROJECT_ID=winged-citron-349012
REGION=us-central1
SERVICE_NAME=zengoal

# --- App ---
PORT=8080

# --- WhatsApp Bridge (opzionale) ---
# WA_SERVICE_URL=https://zengoal-wa-<hash>-uc.a.run.app
# GCS_BUCKET=zengoal-wa-sessions
